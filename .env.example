# ============================================================
# SNAP Bridge — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Server ---
# Host to bind to. Use 127.0.0.1 for localhost-only (recommended).
# Use 0.0.0.0 only if you are behind a reverse proxy with auth.
HOST=127.0.0.1
PORT=3000

# --- Security ---
# Strong random secret — used as Bearer token for all API requests.
# Generate with: openssl rand -hex 32
BRIDGE_TOKEN=change-me-to-a-strong-random-secret

# --- WhatsApp Session ---
# Directory to store multi-file auth credentials. Keep outside web root.
# Must be writable by the Node.js process.
AUTH_STATE_DIR=./auth_state

# --- Webhooks ---
# URL in your Laravel app that the bridge will POST inbound events to.
# Example: http://127.0.0.1:8000/whatsapp/webhook
LARAVEL_WEBHOOK_URL=
# Shared secret for signing webhook payloads (HMAC-SHA256).
# Must match WHATSAPP_BRIDGE_WEBHOOK_SECRET in Laravel .env.
LARAVEL_WEBHOOK_SECRET=

# --- Logging ---
# "production" = JSON output. "development" = pretty-printed.
NODE_ENV=production
# "info" | "debug" | "warn" | "error"
LOG_LEVEL=info

# --- Rate Limiting ---
# Max requests per window per IP on protected write endpoints.
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000
